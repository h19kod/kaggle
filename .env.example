PROJECT_NAME="Kaggle-like Data Science Platform"
DATABASE_URL="sqlite:///./kaggle_platform.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/kaggle_platform"
SECRET_KEY="change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Object Storage (MinIO)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_NAME="kaggle-platform"
S3_REGION="us-east-1"
S3_USE_SSL="false"

# Docker
DATA_SCIENCE_IMAGE="jupyter/datascience-notebook:latest"
